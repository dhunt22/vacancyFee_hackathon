# Large data files (distribute via Google Drive, not Git)
*.gpkg
*.csv
*.geojson
*.kml
*.xlsx
*.zip

# Raw source data
data/
hackathon_data/raw_data/

# Pipeline outputs that can be regenerated
parcel_actualValue/QC/                       # external (Jeff's) input data
parcel_actualValue/shapefiles/               # rebuilt by export_shapefile.py
parcel_actualValue/qc_parcel_diffs.csv       # rebuilt by compare_qc.py
parcel_actualValue/three_way_diffs.csv       # rebuilt by compare_three_way.py

# Generated binary docs
*.docx

# Python
__pycache__/
*.pyc
*.pyo

# Jupyter
.ipynb_checkpoints/

# System / IDE
*.stackdump
bash.exe.stackdump
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code project files
.claude/

# One-off / setup scripts (not part of public pipeline)
scripts/


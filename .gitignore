# Large data files (distribute via Google Drive, not Git)
*.gpkg
*.csv
*.geojson
*.kml
*.xlsx
*.zip

# Raw source data
data/
hackathon_data/raw_data/

# Pipeline outputs that can be regenerated.
# NOTE: git does NOT support inline (end-of-line) comments in .gitignore — a
# trailing "# ..." becomes part of the pattern and silently matches nothing.
# That defect is why the 400 MB shapefiles slipped into history. Keep comments
# on their own lines.
parcel_actualValue/QC/
parcel_actualValue/shapefiles/
parcel_actualValue/qc_parcel_diffs.csv
parcel_actualValue/three_way_diffs.csv

# Generated binary docs
*.docx

# Python
__pycache__/
*.pyc
*.pyo

# Jupyter
.ipynb_checkpoints/

# System / IDE
*.stackdump
bash.exe.stackdump
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code project files
.claude/

# One-off / setup scripts (not part of public pipeline)
scripts/

# Map-suite intermediates — regenerated by maps/prep_layers.py + render_maps.py
# (hs_311.gpkg is already covered by *.gpkg above; the density rasters here):
maps/data/*.tif
maps/_render.log

# Already-committed figures + summary reports stay tracked (hackathon deliverable);
# delete the lines above if you want to remove them and regenerate locally only.
# To stop tracking generated artifacts going forward:
#   git rm --cached parcel_actualValue/figures/*.png parcel_actualValue/*.txt parcel_actualValue/prop13_deflator.csv
